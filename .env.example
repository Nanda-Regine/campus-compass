# ============================================================
# Campus Compass — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ──────────────────────────────────────────────────
# Your deployed URL (or http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OpenAI (Nova AI Companion) ───────────────────────────────
# Found in: https://platform.openai.com/api-keys
# IMPORTANT: This must ONLY be used server-side (API routes).
# NEVER expose this in client-side code.
OPENAI_API_KEY=sk-your-openai-key-here

# ─── PayFast (Premium Subscriptions) ─────────────────────────
# Found in: PayFast Merchant Dashboard → Integration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
# Set to "true" for sandbox testing, "false" for production
PAYFAST_SANDBOX=true
