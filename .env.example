# =====================================================================
# VarsityOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =====================================================================

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://varsityos.co.za

# ── Anthropic (Nova AI) ───────────────────────────────────────────────
# Server-side only — NEVER prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-...

# ── PayFast ───────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
# Set to false in production (true = sandbox mode, payments not real)
PAYFAST_SANDBOX=false

# ── Analytics ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_token
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_HOTJAR_ID=

# ── Error Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=https://your_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id
# Required for Sentry source map uploads in CI
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ── Bot Protection (Arcjet — optional) ────────────────────────────────
ARCJET_KEY=ajkey_your_key

# ── Push Notifications (Firebase FCM + VAPID) ─────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:your_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# ── Weather (OpenWeatherMap) ──────────────────────────────────────
# Free tier: 1 000 calls/day. Get key at openweathermap.org/api
OPENWEATHER_API_KEY=your_owm_api_key

# ── WhatsApp Bot (Meta WhatsApp Business API) ─────────────────────────
# 1. Create a Meta App at developers.facebook.com → add WhatsApp product
# 2. Set webhook callback URL to: https://your-domain/api/whatsapp/webhook
# 3. Subscribe to the "messages" field
META_WHATSAPP_APP_SECRET=your_app_secret
META_WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_VERIFY_TOKEN=choose_any_random_secret_string

# ── Live Chat (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ── Google Search Console ─────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=
