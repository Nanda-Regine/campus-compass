# =====================================================================
# VarsityOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =====================================================================

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://varsityos.co.za

# ── Anthropic (Nova AI) ───────────────────────────────────────────────
# Server-side only — NEVER prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-...

# ── PayFast ───────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
# Set to false in production (true = sandbox mode, payments not real)
PAYFAST_SANDBOX=false

# ── Analytics ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-W7R77VP9
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_token
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_HOTJAR_ID=

# ── Error Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=https://your_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id

# ── Push Notifications ────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# ── Live Chat (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ── Google Search Console ─────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=
