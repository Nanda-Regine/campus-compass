{
  "id": "https://varsityos.co.za/",
  "name": "VarsityOS",
  "short_name": "VarsityOS",
  "description": "The free super-app for South African university students. Study planner, NSFAS tracker, budget manager, meal prep, and Nova AI companion.",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#080f0e",
  "theme_color": "#0d9488",
  "orientation": "portrait-primary",
  "categories": [
    "education",
    "productivity",
    "lifestyle"
  ],
  "lang": "en-ZA",
  "dir": "ltr",
  "icons": [
    {
      "src": "/favicon.jpg",
      "sizes": "any",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/images/screenshot-dashboard.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard — your student life at a glance"
    }
  ],
  "shortcuts": [
    {
      "name": "Study Planner",
      "short_name": "Study",
      "description": "Track tasks, timetable, exams and use Pomodoro timer",
      "url": "/study",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Budget & NSFAS",
      "short_name": "Budget",
      "description": "Track NSFAS allowances and log expenses",
      "url": "/budget",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Nova AI",
      "short_name": "Nova",
      "description": "Chat with your AI study and wellness companion",
      "url": "/nova",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Meal Prep",
      "short_name": "Meals",
      "description": "Plan affordable student meals with AI recipes",
      "url": "/meals",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=co.za.varsityos.app",
      "id": "co.za.varsityos.app"
    }
  ],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/nova",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/budget",
      "accept": {
        "application/pdf": [
          ".pdf"
        ]
      },
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}